# Database
DATABASE_URL=postgresql://knowledge_user:knowledge_pass@localhost:5432/ai_knowledge_platform
DATABASE_URL_ASYNC=postgresql+asyncpg://knowledge_user:knowledge_pass@localhost:5432/ai_knowledge_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# BGE-M3 Embedding Model
BGE_M3_MODEL_PATH=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=gpt-3.5-turbo
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# Chunk Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval Configuration
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.5

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@example.com
